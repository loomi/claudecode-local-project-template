// Prisma schema. See https://www.prisma.io/docs/concepts/components/prisma-schema
// After editing this file, run:
//   npx prisma generate         # regenerate the typed client
//   npx prisma migrate dev      # create and apply a development migration
//
// Dual-provider support: this template runs on BOTH SQLite (default, zero-setup
// local dev) and PostgreSQL (recommended for production / multi-pod). The active
// provider is chosen by the DATABASE_PROVIDER env var (sqlite | postgresql).
//
// IMPORTANT — do NOT hand-edit the `provider` line below. Prisma requires it to
// be a static literal (it cannot be env()), so the setup script swaps it to the
// chosen provider via scripts/db-prepare.{sh,ps1}. The committed value is
// `sqlite` so local dev works out of the box.
//
// Migrations are kept per-provider under prisma/migrations-{provider}/ and the
// active set is COPIED into prisma/migrations/ at setup time (that dir is
// git-ignored generated state). Never edit prisma/migrations/ by hand — edit the
// per-provider source dirs and let db-prepare copy them in.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  name          String?
  password      String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}
