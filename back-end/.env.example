# Application
NODE_ENV=development
PORT=3001

# Swagger UI mount path (served at http://host:port/<SWAGGER_PATH>)
SWAGGER_PATH=docs

# CORS allow-list (comma-separated origins). Empty = allow any origin (dev).
# In production set this to your front-end origin(s), e.g.
# CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=

# Database provider. Valid values: sqlite | postgresql
# SQLite is the zero-setup default for local dev. The setup script swaps the
# Prisma datasource provider + migrations to match this value.
DATABASE_PROVIDER=sqlite

# SQLite database file (relative to back-end/prisma/).
# Zero-setup local dev — no external DB to install.
DATABASE_URL="file:./dev.db"

# For PostgreSQL (recommended for production / multi-pod):
# DATABASE_PROVIDER=postgresql
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# JWT auth
# Replace JWT_ACCESS_SECRET with a long random string in any non-dev environment.
JWT_ACCESS_SECRET=dev-only-change-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
